PORT=4000

# Auth PINs del dashboard (Next.js los lee desde Vercel env vars)
# DEPRECATED — usar los específicos por sucursal (abajo)
# AUTH_VENDEDOR_PIN=xxxx
# AUTH_ADMIN_PIN=xxxx

# PINs por cuenta (nuevos — reemplazar xxxx con valores reales)
AUTH_VENDEDOR_MELIPILLA_PIN=xxxx
AUTH_VENDEDOR_SAN_FELIPE_PIN=xxxx
AUTH_ADMIN_PIN=xxxx
AUTH_SECRET=cambia-este-secreto-en-prod

# Configuración WhatsApp Cloud API (Meta)
WHATSAPP_VERIFY_TOKEN=tu_token_de_verificacion_seguro
WHATSAPP_PHONE_ID=tu_phone_number_id
WHATSAPP_ACCESS_TOKEN=tu_access_token_de_meta

# Meta producción (post-verificación del negocio)
# Versión de la Graph API: producción debe ir en v21.0 (default si no se setea)
WHATSAPP_API_VERSION=v21.0
# WhatsApp Business Account ID (visible en Business Manager → WhatsApp Accounts)
WHATSAPP_BUSINESS_ACCOUNT_ID=
# App Secret y App ID — necesarios para validar la firma X-Hub-Signature-256 del webhook
META_APP_SECRET=
META_APP_ID=

# Debounce del agente (ms). Dev: 5000. Producción recomendado: 20000.
WHATSAPP_DEBOUNCE_MS=5000

# Configuración Google Gemini AI
GEMINI_API_KEY=tu_api_key_de_google_ai_studio

# Supabase (PostgreSQL)
# ⚠️ Usar la 'service_role' key del panel de Supabase → Settings → API
# NUNCA subir el .env real a GitHub
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu_service_role_secret_key

# URL para solicitar reseñas de Google (HU-6)
GOOGLE_REVIEW_URL=https://g.page/r/XXXX/review

# Métricas: segundos estimados que tomaría al vendedor responder cada mensaje
# que respondió la IA. Se usa para calcular "tiempo ahorrado" en el dashboard.
IA_TIEMPO_RESPUESTA_SEG=30

# Auto-archivo de sesiones inactivas (horas). Default 48.
AUTO_ARCHIVE_HOURS=48
