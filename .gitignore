# Dependency directories
node_modules/
jspm_packages/

# Next.js build output
.next/
out/

# Production build
build/
dist/

# Env files — protección en toda la estructura del monorepo
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Subdirectorios del monorepo
backend/.env
backend/.env.local
dashboard/.env
dashboard/.env.local
# Cualquier .env en subdirectorios (cobertura total)
**/.env
**/.env.local
# Archivos de producción con credenciales (NO subir a GitHub)
**/.env.production
backend/.env.production
dashboard/.env.production

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# Design Inspo (User Rule)
designInspo/
!designInspo/design.md

# HU-7: Knowledge base generada dinamicamente (no versionar)
backend/data/knowledge.json

# Documentación con información sensible (claves, tokens, contexto interno)
documentacion/CONTEXTO_IA_TRANSFER.md
documentacion/**/*SECRETS*
documentacion/**/*SECRET*
documentacion/**/*CREDENCIALES*
documentacion/**/*_PRIVATE*
# Archivos de credenciales y llaves en cualquier lugar del repo
**/credentials.json
**/secrets.json
**/*.pem
**/*.key
**/service-account*.json
